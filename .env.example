# Database
DATABASE_URL="postgresql://..."

# JWT
JWT_SECRET="your-super-secret-jwt-key"
JWT_REFRESH_SECRET="your-super-secret-refresh-key"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Server
PORT=5555
NODE_ENV="production"

# Client URL (CORS) — isi dengan URL Vercel setelah deploy FE
CLIENT_URL="https://budgetly.vercel.app"

# ML Service — isi dengan URL Render AI Engine setelah deploy
ML_SERVICE_URL="https://budgetly-ai.onrender.com"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"